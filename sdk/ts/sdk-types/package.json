{
  "name": "@focus-dashboard/sdk-types",
  "version": "0.10.0",
  "description": "TypeScript types and base classes for Focus Dashboard dynamic modules",
  "license": "MIT",
  "author": "awbait",
  "type": "module",
  "types": "./src/index.ts",
  "bin": {
    "focus-build": "./src/build.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./globals": {
      "types": "./src/globals.d.ts"
    },
    "./build": {
      "default": "./src/build.ts"
    }
  },
  "files": [
    "src"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": ">=18",
    "@types/react-dom": ">=18"
  }
}
