{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Community Modules Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "author", "description", "version", "download_url"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$",
        "description": "Unique module identifier (kebab-case)"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Human-readable module name"
      },
      "author": {
        "type": "string",
        "minLength": 1,
        "description": "Module author (GitHub username)"
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "description": "Short module description"
      },
      "version": {
        "type": "string",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+",
        "description": "Semver version"
      },
      "download_url": {
        "type": "string",
        "pattern": "^https://",
        "description": "HTTPS URL to module ZIP"
      },
      "repo": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_-]+$",
        "description": "GitHub repo (owner/name)"
      },
      "homepage": {
        "type": "string",
        "pattern": "^https://",
        "description": "Module homepage URL"
      },
      "preview_url": {
        "type": "string",
        "pattern": "^https://",
        "description": "URL to preview image"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": "Search tags (kebab-case)"
      }
    }
  }
}
